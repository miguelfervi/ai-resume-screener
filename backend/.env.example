# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Used when the primary model returns free-tier 429 / quota errors
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# Paths (relative to backend/)
CHROMA_PATH=../data/chroma
CVS_PATH=../data/cvs
PHOTOS_PATH=../data/cvs/photos

# RAG retrieval
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.65
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
# Pause between embed batches during ingest (raise if free-tier 429s)
EMBED_BATCH_PAUSE_SEC=2

# LLM
LLM_TEMPERATURE=0.0

# API
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
